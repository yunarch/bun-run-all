{
  "$schema": "https://json.schemastore.org/package",
  "name": "@yunarch/bun-run-all",
  "version": "0.0.1",
  "description": "Run given package scripts in parallel or sequential by using bun.",
  "license": "MIT",
  "keywords": [
    "bun",
    "run",
    "all",
    "parallel",
    "sequential",
    "scripts",
    "package-scripts"
  ],
  "author": {
    "name": "Adrian Lopez Gonzalez",
    "url": "https://github.com/yunarch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yunarch/bun-run-all.git"
  },
  "bugs": {
    "url": "https://github.com/yunarch/bun-run-all/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "README.md",
    "LICENSE.md",
    "dist"
  ],
  "engines": {
    "bun": ">=1.2.0"
  },
  "bin": {
    "bun-run-all": "dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "husky && bun run gen",
    "gen": "bun run ./scripts/docsgen.ts",
    "lint": "bun run --parallel lint:code lint:ts",
    "lint:code": "oxlint --type-aware",
    "lint:ts": "tsc --noEmit",
    "format": "oxfmt format --check ./",
    "format:all": "oxfmt format --write ./",
    "clean": "rimraf dist",
    "build": "bun build ./src/index.ts --outdir ./dist --minify --target node --format esm --external commander",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:dist": "bun run build && TEST_DIST=true bun run test"
  },
  "dependencies": {
    "commander": "14.0.3"
  },
  "devDependencies": {
    "@yunarch/config-web": "0.7.7",
    "oxfmt": "0.37.0",
    "oxlint": "1.52.0",
    "oxlint-tsgolint": "0.16.0",
    "husky": "9.1.7",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "@types/node": "25.4.0",
    "@types/bun": "1.3.10"
  },
  "packageManager": "bun@1.3.10"
}
